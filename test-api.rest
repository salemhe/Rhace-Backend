### Vendor Onboarding & Drink Creation Tests
### Use this file with VS Code REST Client extension
### Replace values in {{}} with actual values from responses

@baseUrl = http://localhost:5000
@vendorEmail = testclub@example.com
@vendorPassword = password123

### Variables (Update these after each request)
@vendorToken = YOUR_TOKEN_HERE
@vendorId = YOUR_VENDOR_ID_HERE
@categoryId = YOUR_CATEGORY_ID_HERE
@drinkId = YOUR_DRINK_ID_HERE

###############################################
### STEP 1: Register Vendor
###############################################
POST {{baseUrl}}/api/vendors/auth/register
Content-Type: application/json

{
  "businessName": "Test Night Club",
  "email": "{{vendorEmail}}",
  "password": "{{vendorPassword}}"
}

###############################################
### STEP 2: Verify OTP
### NOTE: Check your email/console for OTP
###############################################
POST {{baseUrl}}/api/vendors/auth/verify-otp
Content-Type: application/json

{
  "email": "{{vendorEmail}}",
  "otp": "123456"
}

###############################################
### STEP 3: Login Vendor
### SAVE the token from response!
###############################################
POST {{baseUrl}}/api/vendors/auth/login
Content-Type: application/json

{
  "email": "{{vendorEmail}}",
  "password": "{{vendorPassword}}"
}

###############################################
### STEP 4: Complete Onboarding
### UPDATE @vendorToken above with token from Step 3
### This tests the ageLimit fix ("18+" should work now!)
###############################################
POST {{baseUrl}}/api/vendors/auth/onboard
Content-Type: application/json
Authorization: Bearer {{vendorToken}}

{
  "vendorType": "club",
  "profileImages": ["https://example.com/club-image.jpg"],
  "address": "123 Party Street, Lagos, Nigeria",
  "phone": "+2348012345678",
  "businessDescription": "The hottest nightclub in town with amazing vibes and great music",
  "website": "https://testnightclub.com",
  "priceRange": 5000,
  "accountName": "Test Night Club Limited",
  "accountNumber": "0123456789",
  "bankName": "Access Bank",
  "bankCode": "044",
  "openingTime": "20:00",
  "closingTime": "04:00",
  "slots": 200,
  "categories": ["nightclub", "lounge", "bar"],
  "dressCode": ["smart casual", "formal"],
  "ageLimit": "18+",
  "offer": "Happy Hour: 50% off all drinks from 8pm-10pm"
}

###############################################
### STEP 5: Login Again (Get New Token)
### IMPORTANT: Update @vendorToken with NEW token
###############################################
POST {{baseUrl}}/api/vendors/auth/login
Content-Type: application/json

{
  "email": "{{vendorEmail}}",
  "password": "{{vendorPassword}}"
}

###############################################
### STEP 6: Create Drink Category
### UPDATE @vendorId with vendor _id from login
### SAVE categoryId from response!
###############################################
POST {{baseUrl}}/api/drinks/categories
Content-Type: application/json
Authorization: Bearer {{vendorToken}}

{
  "clubId": "{{vendorId}}",
  "name": "Cocktails",
  "description": "Premium mixed drinks",
  "icon": "🍹"
}

###############################################
### STEP 7: Get All Categories
###############################################
GET {{baseUrl}}/api/drinks/categories?clubId={{vendorId}}
Authorization: Bearer {{vendorToken}}

###############################################
### STEP 8: Create Drink
### UPDATE @categoryId with category _id from Step 6
### SAVE drinkId from response!
###############################################
POST {{baseUrl}}/api/drinks
Content-Type: application/json
Authorization: Bearer {{vendorToken}}

{
  "clubId": "{{vendorId}}",
  "name": "Mojito",
  "category": "{{categoryId}}",
  "volume": "500ml",
  "price": 2500,
  "quantity": 50,
  "images": ["https://example.com/mojito.jpg"],
  "status": "active",
  "showOnBookingScreen": true
}

###############################################
### STEP 9: Get All Drinks
###############################################
GET {{baseUrl}}/api/drinks?clubId={{vendorId}}
Authorization: Bearer {{vendorToken}}

###############################################
### STEP 10: Get Single Drink
### UPDATE @drinkId with drink _id from Step 8
###############################################
GET {{baseUrl}}/api/drinks/{{drinkId}}
Authorization: Bearer {{vendorToken}}

###############################################
### STEP 11: Update Drink
###############################################
PUT {{baseUrl}}/api/drinks/{{drinkId}}
Content-Type: application/json
Authorization: Bearer {{vendorToken}}

{
  "price": 3000,
  "quantity": 75
}

###############################################
### STEP 12: Delete Drink
###############################################
DELETE {{baseUrl}}/api/drinks/{{drinkId}}
Authorization: Bearer {{vendorToken}}

